{
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api?__pathname=/api"
    },
    {
      "source": "/api/:path*",
      "destination": "/api?__pathname=/api/:path*"
    },
    {
      "source": "/robots.txt",
      "destination": "/api?__pathname=/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api?__pathname=/sitemap.xml"
    }
  ]
}
