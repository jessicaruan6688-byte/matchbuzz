APP_HOST=127.0.0.1
PORT=3000
SITE_URL=
DATA_DIR=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
TURSO_SYNC_INTERVAL_MS=15000

# Optional Turso bootstrap inputs
TURSO_PLATFORM_API_TOKEN=
TURSO_ORG_SLUG=
TURSO_DB_NAME=matchbuzz-prod
TURSO_GROUP_NAME=default
TURSO_GROUP_LOCATION=lhr

# Real LLM provider
# Defaults already point to GMI chat completions.
GMI_API_URL=https://api.gmi-serving.com/v1/chat/completions
GMI_API_KEY=
GMI_MODEL=MiniMaxAI/MiniMax-M2.7
LLM_API_STYLE=openai-chat
LLM_API_AUTH_HEADER=Authorization
LLM_API_AUTH_PREFIX=Bearer

# Real match data provider
MATCH_DATA_API_URL=
MATCH_DATA_API_KEY=
MATCH_DATA_API_STYLE=matchbuzz-json
MATCH_DATA_API_AUTH_HEADER=Authorization
MATCH_DATA_API_AUTH_PREFIX=Bearer
MATCH_DATA_CACHE_MS=300000

# Real football fixtures provider
REAL_FIXTURE_API_URL=https://www.thesportsdb.com/api/v1/json/123
REAL_FIXTURE_LEAGUE_ID=4328
REAL_FIXTURE_SEASON=2025-2026
REAL_FIXTURE_CACHE_MS=300000
